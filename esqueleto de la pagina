<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oracle - Página Corporativa</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#f4f4f4;
color:#333;
}

/* HEADER */

header{
background:#c74634;
color:white;
padding:20px 10%;
display:flex;
justify-content:space-between;
align-items:center;
}

nav ul{
display:flex;
list-style:none;
gap:25px;
}

nav a{
color:white;
text-decoration:none;
}

/* HERO */

.hero{
padding:100px 10%;
text-align:center;
background:#eeeeee;
}

.hero h1{
font-size:40px;
margin-bottom:20px;
}

/* SECCIONES */

section{
padding:80px 10%;
}

/* GRID SERVICIOS */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:white;
padding:25px;
border:1px solid #ddd;
}

/* CTA */

.cta{
background:#222;
color:white;
text-align:center;
}

/* FOOTER */

footer{
background:#111;
color:#aaa;
padding:40px 10%;
display:flex;
justify-content:space-between;
flex-wrap:wrap;
}

.copy{
background:#000;
text-align:center;
padding:10px;
font-size:14px;
}

</style>

</head>

<body>

<!-- HEADER -->

<header>

<h2>ORACLE</h2>

<nav>
<ul>
<li><a href="#">Productos</a></li>
<li><a href="#">Soluciones</a></li>
<li><a href="#">Clientes</a></li>
<li><a href="#">Recursos</a></li>
<li><a href="#">Contacto</a></li>
</ul>
</nav>

</header>


<!-- HERO -->

<section class="hero">

<h1>Tecnología para empresas</h1>
<p>Soluciones modernas en la nube</p>

</section>


<!-- SERVICIOS -->

<section>

<h2>Nuestras soluciones</h2>

<div class="grid">

<div class="card">
<h3>Cloud</h3>
<p>Infraestructura en la nube.</p>
</div>

<div class="card">
<h3>Database</h3>
<p>Bases de datos empresariales.</p>
</div>

<div class="card">
<h3>AI</h3>
<p>Automatización con inteligencia artificial.</p>
</div>

</div>

</section>


<!-- CTA -->

<section class="cta">

<h2>Empieza hoy</h2>
<p>Descubre nuestras soluciones empresariales</p>

</section>


<!-- FOOTER -->

<footer>

<div>
<h4>Empresa</h4>
<p>Sobre nosotros</p>
<p>Noticias</p>
</div>

<div>
<h4>Productos</h4>
<p>Cloud</p>
<p>Database</p>
</div>

<div>
<h4>Soporte</h4>
<p>Documentación</p>
<p>Contacto</p>
</div>

</footer>

<div class="copy">
© 2026 Oracle Template
</div>

</body>

</html>