<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mapa del Sitio Profesional</title>
  <style>
    /* --- Estilos generales --- */
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
      background-color: #f4f6f8;
      color: #333;
    }

    header {
      background-color: #2c3e50;
      color: white;
      padding: 20px;
      text-align: center;
    }

    header h1 {
      margin: 0;
      font-size: 2rem;
      letter-spacing: 1px;
    }

    main {
      max-width: 900px;
      margin: 40px auto;
      background-color: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    p {
      font-size: 1.1rem;
      margin-bottom: 20px;
    }

    /* --- Mapa del sitio --- */
    ul.sitemap {
      list-style: none;
      padding-left: 0;
    }

    ul.sitemap li {
      margin: 10px 0;
      position: relative;
    }

    ul.sitemap a {
      text-decoration: none;
      color: #2980b9;
      font-weight: 500;
      transition: color 0.3s;
    }

    ul.sitemap a:hover {
      color: #1abc9c;
    }

    /* --- Submenú desplegable --- */
    .submenu {
      list-style: none;
      padding-left: 20px;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .submenu li {
      margin: 8px 0;
    }

    .toggle::after {
      content: "▼";
      font-size: 0.7rem;
      margin-left: 8px;
      transition: transform 0.3s;
    }

    .toggle.active::after {
      transform: rotate(-180deg);
    }

  </style>
</head>
<body>

  <header>
    <h1>Mapa del Sitio</h1>
  </header>

  <main>
    <p>Explora todas las secciones de nuestro sitio web de forma clara y organizada:</p>

    <ul class="sitemap">
      <li><a href="index.html">Inicio</a></li>
      <li><a href="nosotros.html">Nosotros</a></li>
      <li>
        <a href="#" class="toggle">Servicios</a>
        <ul class="submenu">
          <li><a href="servicios/web.html">Desarrollo Web</a></li>
          <li><a href="servicios/seo.html">SEO</a></li>
          <li><a href="servicios/marketing.html">Marketing Digital</a></li>
        </ul>
      </li>
      <li>
        <a href="#" class="toggle">Blog</a>
        <ul class="submenu">
          <li><a href="blog/noticias.html">Noticias</a></li>
          <li><a href="blog/tutoriales.html">Tutoriales</a></li>
          <li><a href="blog/casos.html">Casos de Estudio</a></li>
        </ul>
      </li>
      <li><a href="contacto.html">Contacto</a></li>
    </ul>
  </main>

  <script>
    // Hacer que los submenús se desplieguen al hacer clic
    const toggles = document.querySelectorAll('.toggle');

    toggles.forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        const submenu = this.nextElementSibling;
        this.classList.toggle('active');
        if(submenu.style.maxHeight) {
          submenu.style.maxHeight = null;
        } else {
          submenu.style.maxHeight = submenu.scrollHeight + "px";
        }
      });
    });
  </script>

</body>
</html>